# Supabase (required)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_PROJECT_ID="your-project-id"

# Vite-exposed Supabase config (must match SUPABASE_ vars)
VITE_SUPABASE_URL="${SUPABASE_URL}"
VITE_SUPABASE_PUBLISHABLE_KEY="${SUPABASE_PUBLISHABLE_KEY}"
VITE_SUPABASE_PROJECT_ID="${SUPABASE_PROJECT_ID}"

# Supabase service role key (server-side only, do NOT expose to client)
# Required for admin operations in server functions.
# Set this as a secret in your deployment environment.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── AI provider (server-side only) ──────────────────────────────────────────
# Primary: Claude via the official Anthropic SDK. Required for AI chat/insights.
# Get an API key at https://platform.claude.com → API Keys.
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL="claude-opus-4-8"          # chat advisor model (default)
# AI_MODEL_LIGHT="claude-haiku-4-5"   # optional faster model for insight cards (defaults to AI_MODEL)

# Fallback: any OpenAI-compatible provider — used ONLY when ANTHROPIC_API_KEY is unset.
# The app POSTs to `${AI_BASE_URL}/chat/completions` with a Bearer token.
#   Kimi / Moonshot : https://api.moonshot.cn/v1        (models: kimi-k2-0905-preview)
#   OpenAI          : https://api.openai.com/v1         (models: gpt-4o, gpt-4o-mini)
#   OpenRouter      : https://openrouter.ai/api/v1      (models: google/gemini-2.5-flash, ...)
#   Gemini          : https://generativelanguage.googleapis.com/v1beta/openai  (models: gemini-2.5-flash)
# AI_BASE_URL="https://api.moonshot.cn/v1"
# AI_API_KEY="your-provider-api-key"

# Legacy fallback: if neither of the above is set, the Lovable AI Gateway is used with this key.
# LOVABLE_API_KEY="your-lovable-api-key"

# Rate limiter persistence (optional, Node.js only)
# Path to a JSON file where rate limiter state is persisted across restarts.
# Set this to a writable file path (e.g., /tmp/rate-limiter.json).
# When unset, rate limit state is in-memory only (resets on restart).
# RATE_LIMITER_FILE="/tmp/breezkit-rate-limiter.json"

# Rate limiter disable (optional)
# Set to "true" or "1" to bypass all rate limiting.
# Use ONLY in development / isolated testing environments.
# DISABLE_RATE_LIMITER="true"
